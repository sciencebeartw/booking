{
    "rules": {
        ".read": false,
        // иӘІзЁӢгҖҒж©«е№…гҖҒең–еә« (дҝқз•ҷеҡҙж јзҷҪеҗҚе–®й©—иӯү)
        "courses": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "banners": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "trial_banners": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "trial_banner_gallery": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "print_layouts": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "banner_gallery": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "cover_gallery": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "admins": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            ".write": false
        },
        // зі»зөұиЁӯе®ҡ (Webhook URL, Templates зӯү)
        "settings": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        // еҖҷиЈңеҗҚе–®
        "waitlist": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "$courseId": {
                ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
                "$waitId": {
                    ".write": "(auth != null && !data.exists() && newData.exists()) || (auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists())"
                }
            }
        },
        // иЁӮе–®
        "orders": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "$phone": {
                ".read": false,
                ".indexOn": [
                    "orderId"
                ],
                "$orderId": {
                    ".read": true,
                    ".write": "(auth != null && !data.exists() && newData.exists()) || (auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists())"
                }
            }
        },
        // еә§дҪҚпјҡеҠғдҪҚж ёеҝғйӮҸијҜ
        "seats": {
            ".read": true,
            ".indexOn": [
                "status"
            ],
            "$courseId": {
                ".indexOn": [
                    "status"
                ],
                ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
                "_settings": {
                    ".read": true,
                    ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
                },
                "$seatId": {
                    ".write": "
                    // 1. зңҹпјҺз®ЎзҗҶе“Ўж“Ғжңүз„Ўж•өж¬Ҡйҷҗ
            (auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()) ||
            
            // 2. е®¶й•·ж”ҫжЈ„еә§дҪҚпјҡи»ҹеҲӘйҷӨдё”й©—иӯүжң¬дәәUID
            (
              data.exists() && newData.exists() && 
              data.child('status').val() === 'locked' &&
              newData.child('status').val() === 'deleted' && 
              data.child('user').val() === newData.child('user').val() &&
              data.child('user').val() === auth.uid
            ) ||
            
            // 3. еӯёз”ҹе®¶й•·дёҖиҲ¬еҠғдҪҚпјҡдёҠйҺ–иҲҮзөҗеёі (йӣҷйҮҚйҳІиӯ·)
            (
              newData.exists() &&
              $seatId !== '_settings' &&
              
              // жўқд»¶дёҖпјҡеҝ…й ҲеңЁеҗҲжі•й–Ӣж”ҫжҷӮй–“е…§ (ж¶өи“ӢжүҖжңүжўҜж¬Ў)
              (
                (now >= root.child('seats').child($courseId).child('_settings').child('start1').val() && now < root.child('seats').child($courseId).child('_settings').child('end1').val()) ||
                (now >= root.child('seats').child($courseId).child('_settings').child('start2').val() && now < root.child('seats').child($courseId).child('_settings').child('end2').val()) ||
                (now >= root.child('seats').child($courseId).child('_settings').child('t2_start1').val() && now < root.child('seats').child($courseId).child('_settings').child('t2_end1').val()) ||
                (now >= root.child('seats').child($courseId).child('_settings').child('t2_start2').val() && now < root.child('seats').child($courseId).child('_settings').child('t2_end2').val()) ||
                (now >= root.child('seats').child($courseId).child('_settings').child('t3_start1').val() && now < root.child('seats').child($courseId).child('_settings').child('t3_end1').val()) ||
                (now >= root.child('seats').child($courseId).child('_settings').child('t3_start2').val() && now < root.child('seats').child($courseId).child('_settings').child('t3_end2').val())
              ) &&
              
              // жўқд»¶дәҢпјҡеҡҙж јзҡ„зӢҖж…ӢиҪүжҸӣйҷҗеҲ¶ (йҳІжҲӘиғЎж©ҹеҲ¶)
              (
                // жғ…еўғ Aпјҡз©әдҪҚиў«й»һж“ҠдёҠйҺ– (еҸӘиғҪеҫһ null жҲ– deleted и®ҠжҲҗ locked)
                ( 
                  (!data.exists() || data.child('status').val() === 'deleted') && 
                  newData.child('status').val() === 'locked' &&
                  newData.child('user').val() === auth.uid
                ) 
                ||
                // жғ…еўғ BпјҡеЎ«еҜ«е®ҢжҲҗйҖҒеҮәзөҗеёі (еҸӘиғҪеҫһ locked и®ҠжҲҗ soldпјҢдё”еҝ…й Ҳй©—иӯү user ID)
                ( 
                  data.exists() && 
                  data.child('status').val() === 'locked' && 
                  newData.child('status').val() === 'sold' && 
                  data.child('user').val() === newData.child('user').val() &&
                  data.child('user').val() === auth.uid
                )
              )
            )
          "
                }
            }
        },
        "archived_seats": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        // вҳ…вҳ…вҳ… Phase 8 и©ҰиҒҪжҙ»еӢ•иЁӯе®ҡиҲҮзҙ”еҖҷиЈңиЁҲж•ёеҷЁ вҳ…вҳ…вҳ…
        "trial_events_config": {
            ".read": true,
            // ж №зҜҖй»һпјҡеҸӘжңүз®ЎзҗҶе“ЎиғҪеҜ«е…Ҙ
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "$eventId": {
                "sessions": {
                    "$classKey": {
                        "currentWaitlistCount": {
                            // е…ҒиЁұеүҚеҸ°е®¶й•·еҜ«е…ҘпјҢдҪҶгҖҢеҝ…й Ҳзҷ»е…ҘгҖҚгҖҒгҖҢеҝ…й ҲжҳҜж•ёеӯ—гҖҚдё”гҖҢжҜҸж¬ЎеҸӘиғҪ +1гҖҚпјҢйҳІжӯўз«„ж”№иҲҮжҙ—е–®
                            ".write": "auth != null && newData.isNumber() && ( (!data.exists() && newData.val() == 1) || (data.exists() && newData.val() == data.val() + 1) )"
                        }
                    }
                }
            }
        },
        "trial_events": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "registrations": {
                "$eventId": {
                    ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
                    "$uid": {
                        ".write": "newData.exists() && auth != null && auth.uid === $uid"
                    }
                }
            }
        }
    }
}