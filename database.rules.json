{
    "rules": {
        ".read": false,
        // 課程、橫幅、圖庫 (保留嚴格白名單驗證)
        "courses": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "banners": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "trial_banners": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "trial_banner_gallery": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "print_layouts": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "banner_gallery": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "cover_gallery": {
            ".read": true,
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        "admins": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            ".write": false
        },
        // 候補名單
        "waitlist": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "$courseId": {
                "$waitId": {
                    ".write": "( !data.exists() && newData.exists() ) || (auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists())"
                }
            }
        },
        // 訂單
        "orders": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "$phone": {
                ".read": true,
                ".indexOn": [
                    "orderId"
                ],
                "$orderId": {
                    ".write": "( !data.exists() && newData.exists() ) || (auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists())"
                }
            }
        },
        // 座位：劃位核心邏輯
        "seats": {
            ".read": true,
            ".indexOn": [
                "status"
            ],
            "$courseId": {
                ".indexOn": [
                    "status"
                ],
                "_settings": {
                    ".read": true,
                    ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
                },
                "$seatId": {
                    ".write": "
                    // 1. 真．管理員擁有無敵權限
            (auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()) ||
            
            // 2. 家長放棄座位：軟刪除且驗證本人
            (
              data.exists() && newData.exists() && 
              data.child('status').val() === 'locked' &&
              newData.child('status').val() === 'deleted' && 
              data.child('user').val() === newData.child('user').val()
            ) ||
            
            // 3. 學生家長一般劃位：上鎖與結帳 (雙重防護)
            (
              newData.exists() &&
              $seatId !== '_settings' &&
              
              // 條件一：必須在合法開放時間內
              (
                (now >= root.child('seats').child($courseId).child('_settings').child('start1').val() && now < root.child('seats').child($courseId).child('_settings').child('end1').val()) ||
                (now >= root.child('seats').child($courseId).child('_settings').child('start2').val() && now < root.child('seats').child($courseId).child('_settings').child('end2').val())
              ) &&
              
              // 條件二：嚴格的狀態轉換限制 (防截胡機制)
              (
                // 情境 A：空位被點擊上鎖 (只能從 null 或 deleted 變成 locked)
                ( 
                  (!data.exists() || data.child('status').val() === 'deleted') && 
                  newData.child('status').val() === 'locked' 
                ) 
                ||
                // 情境 B：填寫完成送出結帳 (只能從 locked 變成 sold，且必須驗證 user ID)
                ( 
                  data.exists() && 
                  data.child('status').val() === 'locked' && 
                  newData.child('status').val() === 'sold' && 
                  data.child('user').val() === newData.child('user').val() 
                )
              )
            )
          "
                }
            }
        },
        "archived_seats": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
        },
        // ★★★ Phase 8 試聽活動設定與純候補計數器 ★★★
        "trial_events_config": {
            ".read": true,
            // 根節點：只有管理員能寫入
            ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "$eventId": {
                "sessions": {
                    "$classKey": {
                        "currentWaitlistCount": {
                            // 允許前台家長寫入，但「必須是數字」且「每次只能 +1」，防止竄改與洗單
                            ".write": "newData.isNumber() && ( (!data.exists() && newData.val() == 1) || (data.exists() && newData.val() == data.val() + 1) )"
                        }
                    }
                }
            }
        },
        "trial_events": {
            ".read": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()",
            "current_token": {
                ".read": true,
                ".write": "auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()"
            },
            "registrations": {
                "$eventId": {
                    "$registration_id": {
                        ".write": "(auth != null && auth.token.email != null && root.child('admins').child(auth.token.email.replace('.', ',').replace('.', ',').replace('.', ',')).exists()) || (!data.exists() && newData.exists() && root.child('trial_events/current_token').exists() && newData.child('secureToken').isString() && newData.child('secureToken').val() === root.child('trial_events/current_token').val())"
                    }
                }
            }
        }
    }
}